# Configuração do Banco de Dados

# Opção 1: URI direta (Recomendado para Docker)
DATABASE_URL=postgresql://reveal_user:reveal_password@localhost:5432/reveal_db

# Opção 2: PostgreSQL via variáveis individuais
# POSTGRES_SERVER=localhost
# POSTGRES_USER=reveal_user
# POSTGRES_PASSWORD=reveal_password
# POSTGRES_DB=reveal_db

# Opção 3: SQLite (desenvolvimento sem Docker)
# DATABASE_URL=sqlite:///reveal.db

# Captcha Solver (Opcional - Fallback para 2Captcha)
CAPTCHA_API_KEY=